
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Global user profile",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "avatarUrl": { "type": "string" }
      },
      "required": ["id", "email"]
    },
    "Workspace": {
      "title": "Workspace",
      "type": "object",
      "description": "Multi-tenant container for production teams",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "Job": {
      "title": "Job",
      "type": "object",
      "description": "Production Packet for AI workers (rendering, script gen, etc.)",
      "properties": {
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["queued", "generating", "rendered", "published", "failed", "canceled"] },
        "pipelineStage": { "type": "string", "enum": ["idea", "script", "voice", "render", "upload", "published"] },
        "priority": { "type": "number" },
        "workerNodeId": { "type": "string" },
        "channelId": { "type": "string" },
        "renderConfig": {
          "type": "object",
          "properties": {
            "audio_path": { "type": "string" },
            "image_path": { "type": "string" },
            "filter_graph": { "type": "string" }
          }
        },
        "metadata": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "prompt": { "type": "string" },
            "niche": { "type": "string" }
          }
        }
      },
      "required": ["type", "status"]
    },
    "Channel": {
      "title": "Channel",
      "type": "object",
      "description": "YouTube/TikTok channel managed by the grid",
      "properties": {
        "name": { "type": "string" },
        "niche": { "type": "string" },
        "subscribers": { "type": "number" },
        "views30d": { "type": "number" },
        "status": { "type": "string" },
        "health": { "type": "number" }
      }
    }
  },
  "auth": {
    "providers": ["google"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles"
        }
      },
      {
        "path": "/workspaces/{wsId}",
        "definition": {
          "entityName": "Workspace",
          "schema": { "$ref": "#/backend/entities/Workspace" },
          "description": "Production workspaces"
        }
      },
      {
        "path": "/workspaces/{wsId}/channels/{chId}",
        "definition": {
          "entityName": "Channel",
          "schema": { "$ref": "#/backend/entities/Channel" },
          "description": "Managed YouTube channels"
        }
      },
      {
        "path": "/workspaces/{wsId}/jobs/{jobId}",
        "definition": {
          "entityName": "Job",
          "schema": { "$ref": "#/backend/entities/Job" },
          "description": "Production pipeline queue"
        }
      }
    ]
  }
}
