
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Global user account and profile settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "credits": { "type": "number" },
        "plan": { "type": "string", "enum": ["free", "starter", "pro", "empire"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Video": {
      "title": "Video",
      "description": "A video asset in the production pipeline.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "channelId": { "type": "string" },
        "niche": { "type": "string" },
        "status": { "type": "string", "enum": ["idea", "script", "music", "scene", "video", "thumbnail", "uploaded"] },
        "duration": { "type": "string" },
        "metadata": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "status"]
    },
    "Channel": {
      "title": "Channel",
      "description": "A YouTube channel node managed by the system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "handle": { "type": "string" },
        "niche": { "type": "string" },
        "uploadFrequency": { "type": "string" },
        "stats": { "type": "object" },
        "status": { "type": "string", "enum": ["active", "warming", "paused"] }
      }
    },
    "Analytics": {
      "title": "Analytics",
      "description": "Real-time performance data.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "channelId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "views": { "type": "number" },
        "ctr": { "type": "number" },
        "watchTime": { "type": "number" },
        "revenue": { "type": "number" },
        "rpm": { "type": "number" }
      }
    },
    "Task": {
      "title": "Task",
      "description": "An autonomous agent task in the queue (Active Memory).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" },
        "priority": { "type": "number" },
        "agent": { "type": "string" },
        "payload": { "type": "object" }
      }
    },
    "TrendSignal": {
      "title": "TrendSignal",
      "description": "Live heat map data from social platforms (External Intel).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "source": { "type": "string" },
        "topic": { "type": "string" },
        "velocity": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "AgentRun": {
      "title": "AgentRun",
      "description": "Logs of agent executions including errors/hallucinations (Correction Ledger).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agentId": { "type": "string" },
        "taskId": { "type": "string" },
        "success": { "type": "boolean" },
        "error": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "structure": [
      {
        "path": "/userProfiles/{userId}",
        "definition": { "entityName": "UserProfile", "schema": { "$ref": "#/backend/entities/UserProfile" }, "description": "User profiles." }
      },
      {
        "path": "/userProfiles/{userId}/videos/{videoId}",
        "definition": { "entityName": "Video", "schema": { "$ref": "#/backend/entities/Video" }, "description": "Production pipeline videos." }
      },
      {
        "path": "/userProfiles/{userId}/channels/{channelId}",
        "definition": { "entityName": "Channel", "schema": { "$ref": "#/backend/entities/Channel" }, "description": "Managed YouTube nodes (Institutional Memory)." }
      },
      {
        "path": "/userProfiles/{userId}/analytics/{statId}",
        "definition": { "entityName": "Analytics", "schema": { "$ref": "#/backend/entities/Analytics" }, "description": "Performance metrics." }
      },
      {
        "path": "/userProfiles/{userId}/tasks/{taskId}",
        "definition": { "entityName": "Task", "schema": { "$ref": "#/backend/entities/Task" }, "description": "Agent task queue (Active Memory)." }
      },
      {
        "path": "/userProfiles/{userId}/trendSignals/{signalId}",
        "definition": { "entityName": "TrendSignal", "schema": { "$ref": "#/backend/entities/TrendSignal" }, "description": "Live heat map data (External Intel)." }
      },
      {
        "path": "/userProfiles/{userId}/agentRuns/{runId}",
        "definition": { "entityName": "AgentRun", "schema": { "$ref": "#/backend/entities/AgentRun" }, "description": "Log of agent attempts (Correction Ledger)." }
      }
    ]
  }
}
