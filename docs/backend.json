
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Global user account and profile settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "VideoIdea": {
      "title": "VideoIdea",
      "description": "Concept and niche strategy for a specific video.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "niche": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "processed"] },
        "duration": { "type": "string", "description": "e.g., 3h" },
        "scene_concept": { "type": "string" }
      },
      "required": ["id", "title", "status"]
    },
    "MusicTrack": {
      "title": "MusicTrack",
      "description": "AI-generated Lo-Fi music assets (Suno AI).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "suno_id": { "type": "string" },
        "file_url": { "type": "string" },
        "duration_sec": { "type": "number" },
        "loop_count": { "type": "number" }
      },
      "required": ["id", "file_url"]
    },
    "BackgroundScene": {
      "title": "BackgroundScene",
      "description": "Midjourney/Playground AI generated visual scenes.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "prompt": { "type": "string" },
        "image_url": { "type": "string" },
        "upscaled": { "type": "boolean" }
      },
      "required": ["id", "image_url"]
    },
    "VideoQueue": {
      "title": "VideoQueue",
      "description": "FFmpeg rendering jobs for video assembly.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "status": { "type": "string", "enum": ["queued", "rendering", "completed", "failed"] },
        "output_url": { "type": "string" },
        "worker_id": { "type": "string" }
      },
      "required": ["id", "status"]
    },
    "PublishedVideo": {
      "title": "PublishedVideo",
      "description": "Final uploads scheduled via YouTube Data API.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "youtube_id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "publishedAt": { "type": "string", "format": "date-time" },
        "stats": { "type": "object" }
      },
      "required": ["id", "youtube_id", "title"]
    }
  },
  "firestore": {
    "structure": [
      {
        "path": "/userProfiles/{userId}",
        "definition": { "entityName": "UserProfile", "schema": { "$ref": "#/backend/entities/UserProfile" }, "description": "Root user nodes." }
      },
      {
        "path": "/userProfiles/{userId}/videoIdeas/{ideaId}",
        "definition": { "entityName": "VideoIdea", "schema": { "$ref": "#/backend/entities/VideoIdea" }, "description": "Content queue for ideas." }
      },
      {
        "path": "/userProfiles/{userId}/musicTracks/{trackId}",
        "definition": { "entityName": "MusicTrack", "schema": { "$ref": "#/backend/entities/MusicTrack" }, "description": "Suno generated music tracks." }
      },
      {
        "path": "/userProfiles/{userId}/backgroundScenes/{sceneId}",
        "definition": { "entityName": "BackgroundScene", "schema": { "$ref": "#/backend/entities/BackgroundScene" }, "description": "Midjourney generated visuals." }
      },
      {
        "path": "/userProfiles/{userId}/videoQueue/{jobId}",
        "definition": { "entityName": "VideoQueue", "schema": { "$ref": "#/backend/entities/VideoQueue" }, "description": "FFmpeg assembly queue." }
      },
      {
        "path": "/userProfiles/{userId}/publishedVideos/{videoId}",
        "definition": { "entityName": "PublishedVideo", "schema": { "$ref": "#/backend/entities/PublishedVideo" }, "description": "YouTube publication records." }
      }
    ]
  }
}
