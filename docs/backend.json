
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Global user profile",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "avatarUrl": { "type": "string" }
      },
      "required": ["id", "email"]
    },
    "Workspace": {
      "title": "Workspace",
      "type": "object",
      "description": "Multi-tenant container for production teams",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "Member": {
      "title": "Member",
      "type": "object",
      "description": "User role within a workspace",
      "properties": {
        "role": { "type": "string", "enum": ["owner", "admin", "editor", "viewer"] },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["role"]
    },
    "Job": {
      "title": "Job",
      "type": "object",
      "description": "Queue item for AI workers",
      "properties": {
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["queued", "leased", "running", "succeeded", "failed"] },
        "priority": { "type": "number" },
        "lease": {
          "type": "object",
          "properties": {
            "leasedBy": { "type": "string" },
            "leasedUntil": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["type", "status"]
    },
    "Idea": {
      "title": "Idea",
      "type": "object",
      "description": "Viral concept or topic",
      "properties": {
        "topic": { "type": "string" },
        "niche": { "type": "string" },
        "hook": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["topic", "niche", "status"]
    }
  },
  "auth": {
    "providers": ["google", "password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles"
        }
      },
      {
        "path": "/workspaces/{wsId}",
        "definition": {
          "entityName": "Workspace",
          "schema": { "$ref": "#/backend/entities/Workspace" },
          "description": "Production workspaces"
        }
      },
      {
        "path": "/workspaces/{wsId}/members/{userId}",
        "definition": {
          "entityName": "Member",
          "schema": { "$ref": "#/backend/entities/Member" },
          "description": "Workspace membership and roles"
        }
      },
      {
        "path": "/workspaces/{wsId}/jobs/{jobId}",
        "definition": {
          "entityName": "Job",
          "schema": { "$ref": "#/backend/entities/Job" },
          "description": "Server-leased job queue"
        }
      },
      {
        "path": "/workspaces/{wsId}/ideas/{ideaId}",
        "definition": {
          "entityName": "Idea",
          "schema": { "$ref": "#/backend/entities/Idea" },
          "description": "Content ideas and signals"
        }
      }
    ]
  }
}
