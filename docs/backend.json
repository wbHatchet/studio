
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Global user profile",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "avatarUrl": { "type": "string" }
      },
      "required": ["id", "email"]
    },
    "Workspace": {
      "title": "Workspace",
      "type": "object",
      "description": "Multi-tenant container for production teams",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "Job": {
      "title": "Job",
      "type": "object",
      "description": "Production Packet for AI workers (rendering, script gen, etc.)",
      "properties": {
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["queued", "generating", "rendered", "published", "failed", "canceled"] },
        "priority": { "type": "number" },
        "workerNodeId": { "type": "string", "description": "ID of the Docker/K8s container running the job" },
        "renderConfig": {
          "type": "object",
          "properties": {
            "ffmpegCommand": { "type": "string" },
            "filterGraph": { "type": "string" },
            "fps": { "type": "number", "default": 24 },
            "resolution": { "type": "string", "default": "1280x720" },
            "vintageLevel": { "type": "number", "default": 0.5 }
          }
        },
        "metadata": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "prompt": { "type": "string" },
            "aesthetic": { "type": "string", "default": "vintage_60s" }
          }
        },
        "assets": {
          "type": "object",
          "properties": {
            "audioUrl": { "type": "string" },
            "imageUrl": { "type": "string" },
            "videoUrl": { "type": "string" }
          }
        },
        "lease": {
          "type": "object",
          "properties": {
            "leasedBy": { "type": "string" },
            "leasedUntil": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["type", "status"]
    },
    "Asset": {
      "title": "Asset",
      "type": "object",
      "description": "Media asset stored in video-assets-factory bucket",
      "properties": {
        "type": { "type": "string", "enum": ["scripts", "voice", "clips", "thumbnails", "videos", "music"] },
        "storagePath": { "type": "string", "description": "The GCS path e.g. videos/video1.mp4" },
        "bucket": { "type": "string", "default": "video-assets-factory" },
        "mimeType": { "type": "string" },
        "size": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" },
        "vectorRef": { "type": "string", "description": "Vector record ID" },
        "embedding": { "type": "boolean", "description": "Flag indicating if vector embedding exists" }
      },
      "required": ["type", "storagePath"]
    },
    "Publication": {
      "title": "Publication",
      "type": "object",
      "description": "Metadata for YouTube Data API v3 distribution",
      "properties": {
        "videoId": { "type": "string" },
        "platform": { "type": "string", "enum": ["youtube", "tiktok", "instagram", "facebook"], "default": "youtube" },
        "status": { "type": "string", "enum": ["draft", "scheduled", "published", "failed"] },
        "apiPayload": {
          "type": "object",
          "properties": {
            "part": { "type": "string", "default": "snippet,status" },
            "body": {
              "type": "object",
              "properties": {
                "snippet": {
                  "type": "object",
                  "properties": {
                    "title": { "type": "string" },
                    "description": { "type": "string" },
                    "tags": { "type": "array", "items": { "type": "string" } }
                  }
                },
                "status": {
                  "type": "object",
                  "properties": {
                    "privacyStatus": { "type": "string", "enum": ["public", "unlisted", "private"], "default": "public" }
                  }
                }
              }
            },
            "media_body": { "type": "string", "description": "GCS path to the mp4 file" }
          }
        },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "externalUrl": { "type": "string" }
      },
      "required": ["videoId", "status"]
    }
  },
  "auth": {
    "providers": ["google"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles"
        }
      },
      {
        "path": "/workspaces/{wsId}",
        "definition": {
          "entityName": "Workspace",
          "schema": { "$ref": "#/backend/entities/Workspace" },
          "description": "Production workspaces"
        }
      },
      {
        "path": "/workspaces/{wsId}/assets/{assetId}",
        "definition": {
          "entityName": "Asset",
          "schema": { "$ref": "#/backend/entities/Asset" },
          "description": "Metadata for assets stored in video-assets-factory GCS bucket"
        }
      },
      {
        "path": "/workspaces/{wsId}/publishes/{publishId}",
        "definition": {
          "entityName": "Publication",
          "schema": { "$ref": "#/backend/entities/Publication" },
          "description": "Automation queue for YouTube Data API v3 uploads"
        }
      },
      {
        "path": "/workspaces/{wsId}/jobs/{jobId}",
        "definition": {
          "entityName": "Job",
          "schema": { "$ref": "#/backend/entities/Job" },
          "description": "Enterprise job queue for FFmpeg/AI workers"
        }
      }
    ]
  }
}
