
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email"]
    },
    "Idea": {
      "title": "Idea",
      "type": "object",
      "description": "A viral concept or topic waiting for production.",
      "properties": {
        "topic": { "type": "string" },
        "niche": { "type": "string" },
        "mood": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "error"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["topic", "niche", "status", "createdAt"]
    },
    "Job": {
      "title": "Job",
      "type": "object",
      "description": "A specific AI agent task in the pipeline.",
      "properties": {
        "type": { "type": "string" },
        "status": { "type": "string" },
        "ideaId": { "type": "string" },
        "progress": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "status", "ideaId", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Global user profiles"
    },
    "/users/{userId}/ideas/{ideaId}": {
      "schema": { "$ref": "#/entities/Idea" },
      "description": "Video ideas and topics"
    },
    "/users/{userId}/jobs/{jobId}": {
      "schema": { "$ref": "#/entities/Job" },
      "description": "Active production tasks"
    }
  }
}
