{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Global user account and profile settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "VideoIdea": {
      "title": "VideoIdea",
      "description": "Concept and niche strategy for a video asset.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "niche": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "processed"] },
        "duration": { "type": "string" },
        "ctr_prediction": { "type": "number" }
      },
      "required": ["id", "title", "status"]
    },
    "TrendLog": {
      "title": "TrendLog",
      "description": "Viral signals mined from social platforms.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "subject": { "type": "string" },
        "growth": { "type": "string" },
        "confidence": { "type": "string" },
        "platform": { "type": "string" }
      }
    },
    "Asset": {
      "title": "Asset",
      "description": "Generic media asset (audio, image, video).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["audio", "image", "video"] },
        "storagePath": { "type": "string" },
        "metadata": { "type": "object" }
      }
    }
  },
  "firestore": {
    "structure": [
      {
        "path": "/userProfiles/{userId}",
        "definition": { "entityName": "UserProfile", "schema": { "$ref": "#/backend/entities/UserProfile" }, "description": "User profiles." }
      },
      {
        "path": "/userProfiles/{userId}/videoIdeas/{ideaId}",
        "definition": { "entityName": "VideoIdea", "schema": { "$ref": "#/backend/entities/VideoIdea" }, "description": "Content ideas queue." }
      },
      {
        "path": "/userProfiles/{userId}/trendLogs/{logId}",
        "definition": { "entityName": "TrendLog", "schema": { "$ref": "#/backend/entities/TrendLog" }, "description": "Mined viral signals." }
      },
      {
        "path": "/userProfiles/{userId}/assets/{assetId}",
        "definition": { "entityName": "Asset", "schema": { "$ref": "#/backend/entities/Asset" }, "description": "Production media assets." }
      }
    ]
  }
}