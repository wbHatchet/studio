
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Global user profile",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "avatarUrl": { "type": "string" }
      },
      "required": ["id", "email"]
    },
    "Workspace": {
      "title": "Workspace",
      "type": "object",
      "description": "Multi-tenant container for production teams",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "Member": {
      "title": "Member",
      "type": "object",
      "description": "User role within a workspace",
      "properties": {
        "role": { "type": "string", "enum": ["owner", "admin", "editor", "viewer"] },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["role"]
    },
    "Job": {
      "title": "Job",
      "type": "object",
      "description": "Queue item for AI workers",
      "properties": {
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["queued", "leased", "running", "succeeded", "failed", "canceled"] },
        "priority": { "type": "number" },
        "runAfter": { "type": "string", "format": "date-time" },
        "inputRefs": { "type": "object" },
        "outputRefs": { "type": "object" },
        "lease": {
          "type": "object",
          "properties": {
            "leasedBy": { "type": "string" },
            "leasedUntil": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["type", "status"]
    },
    "Signal": {
      "title": "Viral Signal",
      "type": "object",
      "description": "Trend prediction data from Growth Agents",
      "properties": {
        "type": { "type": "string" },
        "sources": { "type": "array", "items": { "type": "string" } },
        "topics": { "type": "array" },
        "discoveredAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "discoveredAt"]
    },
    "Experiment": {
      "title": "A/B Experiment",
      "type": "object",
      "description": "Thumbnail or Title testing container",
      "properties": {
        "type": { "type": "string", "enum": ["thumbnail_ab", "title_ab"] },
        "publishId": { "type": "string" },
        "status": { "type": "string", "enum": ["running", "done"] },
        "variants": { "type": "array" },
        "winner": { "type": "object" }
      },
      "required": ["type", "status"]
    },
    "CommentTask": {
      "title": "Comment Engagement Task",
      "type": "object",
      "description": "AI-generated comment draft requiring approval",
      "properties": {
        "publishId": { "type": "string" },
        "action": { "type": "string", "enum": ["reply", "heart", "pin"] },
        "draftText": { "type": "string" },
        "status": { "type": "string", "enum": ["pending_approval", "approved", "rejected", "executed"] },
        "approvedBy": { "type": "string" }
      },
      "required": ["action", "status"]
    }
  },
  "auth": {
    "providers": ["google"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles"
        }
      },
      {
        "path": "/workspaces/{wsId}",
        "definition": {
          "entityName": "Workspace",
          "schema": { "$ref": "#/backend/entities/Workspace" },
          "description": "Production workspaces"
        }
      },
      {
        "path": "/workspaces/{wsId}/members/{userId}",
        "definition": {
          "entityName": "Member",
          "schema": { "$ref": "#/backend/entities/Member" },
          "description": "Workspace membership and roles"
        }
      },
      {
        "path": "/workspaces/{wsId}/jobs/{jobId}",
        "definition": {
          "entityName": "Job",
          "schema": { "$ref": "#/backend/entities/Job" },
          "description": "Worker queue items"
        }
      },
      {
        "path": "/workspaces/{wsId}/signals/{signalId}",
        "definition": {
          "entityName": "Signal",
          "schema": { "$ref": "#/backend/entities/Signal" },
          "description": "Trend prediction signals"
        }
      },
      {
        "path": "/workspaces/{wsId}/experiments/{expId}",
        "definition": {
          "entityName": "Experiment",
          "schema": { "$ref": "#/backend/entities/Experiment" },
          "description": "A/B testing experiments"
        }
      },
      {
        "path": "/workspaces/{wsId}/comments/{commentId}",
        "definition": {
          "entityName": "CommentTask",
          "schema": { "$ref": "#/backend/entities/CommentTask" },
          "description": "Comment engagement moderation queue"
        }
      },
      {
        "path": "/workspaces/{wsId}/apiKeyRefs/{keyId}",
        "definition": {
          "schema": "object",
          "description": "Metadata-only secret references"
        }
      }
    ]
  }
}
