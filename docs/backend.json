
{
  "entities": {
    "Organization": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Organization",
      "type": "object",
      "description": "The root of the multi-tenant system, managing teams and billing.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "billingStatus": { "type": "string", "enum": ["active", "past_due", "suspended"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "billingStatus"]
    },
    "NicheTaxonomy": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "NicheTaxonomy",
      "type": "object",
      "description": "Hierarchical classification for the AI Director to estimate profit.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "baseCpmEstimate": { "type": "number" },
        "slug": { "type": "string" }
      },
      "required": ["id", "name", "slug"]
    },
    "Channel": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Channel",
      "type": "object",
      "description": "Managing a YouTube ID within the network grid.",
      "properties": {
        "id": { "type": "string" },
        "orgId": { "type": "string" },
        "ytChannelId": { "type": "string" },
        "nicheId": { "type": "string" },
        "name": { "type": "string" },
        "subscriberCount": { "type": "number" },
        "isActive": { "type": "boolean" },
        "secretManagerRef": { "type": "string", "description": "Pointer to Vault for OAuth tokens." }
      },
      "required": ["id", "orgId", "ytChannelId", "secretManagerRef"]
    },
    "Video": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Video",
      "type": "object",
      "description": "Massive metadata engine for 1M+ videos.",
      "properties": {
        "id": { "type": "string" },
        "channelId": { "type": "string" },
        "status": { "type": "string" },
        "metadata": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" },
            "tags": { "type": "array", "items": { "type": "string" } },
            "aiScore": { "type": "number" }
          }
        },
        "files": {
          "type": "object",
          "properties": {
            "masterMp4": { "type": "string" },
            "thumbnail": { "type": "string" }
          }
        },
        "ytSpecifics": {
          "type": "object",
          "properties": {
            "youtubeVideoId": { "type": "string" },
            "privacyStatus": { "type": "string" }
          }
        }
      },
      "required": ["id", "channelId", "status"]
    },
    "Asset": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Asset",
      "type": "object",
      "description": "Lineage tracking for every stock clip or beat.",
      "properties": {
        "id": { "type": "string" },
        "s3Key": { "type": "string" },
        "type": { "type": "string" },
        "licenseType": { "type": "string" },
        "embeddingId": { "type": "string" }
      },
      "required": ["id", "s3Key", "type"]
    }
  },
  "firestore": {
    "structure": [
      {
        "path": "/organizations/{orgId}",
        "definition": { "entityName": "Organization", "schema": { "$ref": "#/backend/entities/Organization" }, "description": "Root tenants." }
      },
      {
        "path": "/organizations/{orgId}/channels/{channelId}",
        "definition": { "entityName": "Channel", "schema": { "$ref": "#/backend/entities/Channel" }, "description": "Managed channels." }
      },
      {
        "path": "/organizations/{orgId}/channels/{channelId}/videos/{videoId}",
        "definition": { "entityName": "Video", "schema": { "$ref": "#/backend/entities/Video" }, "description": "Video metadata engine." }
      }
    ]
  }
}
