
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Global user profile",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "avatarUrl": { "type": "string" }
      },
      "required": ["id", "email"]
    },
    "Workspace": {
      "title": "Workspace",
      "type": "object",
      "description": "Multi-tenant container for production teams",
      "properties": {
        "name": { "type": "string" },
        "ownerId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "ownerId"]
    },
    "Member": {
      "title": "Member",
      "type": "object",
      "description": "User role within a workspace",
      "properties": {
        "role": { "type": "string", "enum": ["owner", "admin", "editor", "viewer"] },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["role"]
    },
    "Job": {
      "title": "Job",
      "type": "object",
      "description": "Queue item for AI workers",
      "properties": {
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["queued", "leased", "running", "succeeded", "failed", "canceled"] },
        "priority": { "type": "number" },
        "runAfter": { "type": "string", "format": "date-time" },
        "inputRefs": { "type": "object" },
        "outputRefs": { "type": "object" },
        "lease": {
          "type": "object",
          "properties": {
            "leasedBy": { "type": "string" },
            "leasedUntil": { "type": "string", "format": "date-time" }
          }
        }
      },
      "required": ["type", "status"]
    },
    "Asset": {
      "title": "Asset",
      "type": "object",
      "description": "Media asset stored in Google Cloud Storage",
      "properties": {
        "type": { "type": "string", "enum": ["script", "voice", "video", "thumbnail"] },
        "storagePath": { "type": "string", "description": "The GCS path e.g. assets/videos/short.mp4" },
        "mimeType": { "type": "string" },
        "size": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "metadata": { "type": "object" }
      },
      "required": ["type", "storagePath"]
    },
    "Signal": {
      "title": "Viral Signal",
      "type": "object",
      "description": "Trend prediction data from Growth Agents",
      "properties": {
        "type": { "type": "string" },
        "sources": { "type": "array", "items": { "type": "string" } },
        "topics": { "type": "array" },
        "discoveredAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "discoveredAt"]
    }
  },
  "auth": {
    "providers": ["google"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profiles"
        }
      },
      {
        "path": "/workspaces/{wsId}",
        "definition": {
          "entityName": "Workspace",
          "schema": { "$ref": "#/backend/entities/Workspace" },
          "description": "Production workspaces"
        }
      },
      {
        "path": "/workspaces/{wsId}/assets/{assetId}",
        "definition": {
          "entityName": "Asset",
          "schema": { "$ref": "#/backend/entities/Asset" },
          "description": "Metadata for assets stored in GCS assets/ folder"
        }
      }
    ]
  }
}
