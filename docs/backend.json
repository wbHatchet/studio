
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Global user account and profile settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "High-level container for a Lo-Fi channel initiative (e.g., 'Halloween Lofi').",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "name": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "archived"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ownerId", "name"]
    },
    "Job": {
      "title": "Job",
      "description": "An AI agent task in the automation pipeline.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "job_type": { "type": "string", "enum": ["generate_music", "generate_image", "render_video", "metadata_gen", "youtube_upload"] },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "failed"] },
        "payload": { "type": "object" },
        "resultUrl": { "type": "string" }
      },
      "required": ["id", "projectId", "job_type", "status"]
    },
    "Asset": {
      "title": "Asset",
      "description": "Media files stored in Firebase Storage (songs, images, etc.).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["audio", "image", "video", "thumbnail"] },
        "storagePath": { "type": "string", "description": "e.g., /audio/song1.mp3" },
        "metadata": { "type": "object" }
      },
      "required": ["id", "type", "storagePath"]
    },
    "Video": {
      "title": "Video",
      "description": "Final video metadata and YouTube publication status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "channelId": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "scheduled", "published"] },
        "youtubeId": { "type": "string" }
      },
      "required": ["id", "channelId", "title", "status"]
    }
  },
  "firestore": {
    "structure": [
      {
        "path": "/userProfiles/{userId}",
        "definition": { "entityName": "UserProfile", "schema": { "$ref": "#/backend/entities/UserProfile" }, "description": "Root user nodes." }
      },
      {
        "path": "/userProfiles/{userId}/projects/{projectId}",
        "definition": { "entityName": "Project", "schema": { "$ref": "#/backend/entities/Project" }, "description": "User projects." }
      },
      {
        "path": "/userProfiles/{userId}/projects/{projectId}/jobs/{jobId}",
        "definition": { "entityName": "Job", "schema": { "$ref": "#/backend/entities/Job" }, "description": "AI Agent tasks." }
      },
      {
        "path": "/userProfiles/{userId}/projects/{projectId}/assets/{assetId}",
        "definition": { "entityName": "Asset", "schema": { "$ref": "#/backend/entities/Asset" }, "description": "Media asset library." }
      },
      {
        "path": "/userProfiles/{userId}/projects/{projectId}/videos/{videoId}",
        "definition": { "entityName": "Video", "schema": { "$ref": "#/backend/entities/Video" }, "description": "Final video records." }
      }
    ]
  }
}
