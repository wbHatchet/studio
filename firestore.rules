
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow get, list, create, update: if isOwner(userId);
      
      match /ideas/{ideaId} {
        allow read, write: if isOwner(userId);
      }
      
      match /jobs/{jobId} {
        allow read, write: if isOwner(userId);
      }

      match /channels/{channelId} {
        allow read, write: if isOwner(userId);
      }

      match /chatHistory/{chatId} {
        allow read, write: if isOwner(userId);
      }

      match /agentRuns/{runId} {
        // System bypass for industrial logging via secret key
        allow create: if request.resource.data.apiKey == 'INDUSTRIAL_SYSTEM_KEY_2026' || isOwner(userId);
        allow read: if isOwner(userId);
      }
    }
  }
}
