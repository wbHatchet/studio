
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function getRole(wsId) {
      return get(/databases/$(database)/documents/workspaces/$(wsId)/members/$(request.auth.uid)).data.role;
    }
    
    function isMember(wsId) {
      return exists(/databases/$(database)/documents/workspaces/$(wsId)/members/$(request.auth.uid));
    }
    
    function isAtLeast(wsId, role) {
      let r = getRole(wsId);
      return r == 'owner' || r == 'admin' || (role == 'editor' && r == 'editor');
    }

    // --- RULES ---
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    match /workspaces/{wsId} {
      allow read: if isMember(wsId);
      allow create: if isSignedIn();
      allow update, delete: if isAtLeast(wsId, 'admin');

      match /members/{userId} {
        allow read: if isMember(wsId);
        allow write: if isAtLeast(wsId, 'admin');
      }

      match /jobs/{jobId} {
        allow read: if isMember(wsId);
        // Clients can only create jobs in 'queued' state and cannot set lease fields
        allow create: if isAtLeast(wsId, 'editor') 
          && request.resource.data.status == 'queued'
          && !('lease' in request.resource.data);
        allow update: if isAtLeast(wsId, 'admin');
      }

      match /ideas/{ideaId} {
        allow read: if isMember(wsId);
        allow write: if isAtLeast(wsId, 'editor');
      }
      
      match /apiKeyRefs/{keyId} {
        allow read: if isMember(wsId);
        allow write: if isAtLeast(wsId, 'admin');
      }
    }
  }
}
