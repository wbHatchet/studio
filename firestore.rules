
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isSystemWorker() {
      return request.resource.data.apiKey == 'INDUSTRIAL_SYSTEM_KEY_2026';
    }

    match /userProfiles/{userId} {
      allow get, list, create, update, delete: if isOwner(userId);

      match /agentRuns/{runId} {
        allow read: if isOwner(userId);
        // Allow the system log-alert API or background workers to create logs
        allow create: if isOwner(userId) || isSystemWorker();
      }

      match /videoIdeas/{ideaId} {
        allow read, write: if isOwner(userId);
      }
      match /musicTracks/{trackId} {
        allow read, write: if isOwner(userId);
      }
      match /backgroundScenes/{sceneId} {
        allow read, write: if isOwner(userId);
      }
      match /videoQueue/{jobId} {
        allow read, write: if isOwner(userId);
      }
      match /publishedVideos/{videoId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
